@model GiftStoreMVC.Models.Product
@{
    ViewData["Title"] = "Add New Product";
    Layout = "_AdminLayout";
    var categories = ViewBag.Categories as List<GiftStoreMVC.Models.Category>;
}

<div class="row justify-content-center">
    <div class="col-xl-10">
        <div class="admin-card">
            <div class="admin-card-header">
                <h6><i class="bi bi-plus-circle-fill me-2" style="color:var(--accent);"></i>New Product</h6>
                <a asp-action="Index" class="btn btn-sm py-1 px-3 fw-600" style="background:#f3f4f6;color:#374151;border-radius:8px;font-size:0.8rem;text-decoration:none;">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
            <div class="admin-card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" style="font-size:0.85rem;"></div>

                    <div class="row g-4">
                        <!-- LEFT -->
                        <div class="col-md-8">
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label">Product Name</label>
                                <input asp-for="Name" class="form-control" placeholder="e.g. Premium Gift Hamper" />
                                <span asp-validation-for="Name" class="text-danger" style="font-size:0.78rem;"></span>
                            </div>
                            <div class="mb-4">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="7" placeholder="Describe the product in detail..."></textarea>
                                <span asp-validation-for="Description" class="text-danger" style="font-size:0.78rem;"></span>
                            </div>
                        </div>

                        <!-- RIGHT -->
                        <div class="col-md-4">
                            <div class="p-4 rounded-2 mb-4" style="background:#f8f7ff;border:1px solid #ede9fe;">
                                <h6 class="fw-700 mb-3" style="font-size:0.85rem;">Pricing & Stock</h6>
                                <div class="mb-3">
                                    <label asp-for="CategoryId" class="form-label">Category</label>
                                    <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(categories, "Id", "Name"))">
                                        <option value="">Select Category</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger" style="font-size:0.78rem;"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label">Price (₹)</label>
                                    <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                    <span asp-validation-for="Price" class="text-danger" style="font-size:0.78rem;"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="StockQuantity" class="form-label">Stock Quantity</label>
                                    <input asp-for="StockQuantity" class="form-control" type="number" placeholder="0" />
                                    <span asp-validation-for="StockQuantity" class="text-danger" style="font-size:0.78rem;"></span>
                                </div>
                                <div class="d-flex align-items-center gap-3 p-3 rounded-2" style="background:white;border:1px solid #e5e7eb;">
                                    <input class="form-check-input m-0" type="checkbox" asp-for="IsFeatured" style="width:18px;height:18px;accent-color:var(--accent);">
                                    <div>
                                        <label class="form-label mb-0" asp-for="IsFeatured">Featured Product</label>
                                        <p class="text-muted mb-0" style="font-size:0.75rem;">Show on homepage</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- IMAGES -->
                        <div class="col-12">
                            <div class="p-4 rounded-2" style="background:#f8f7ff;border:1px solid #ede9fe;">
                                <h6 class="fw-700 mb-4" style="font-size:0.85rem;"><i class="bi bi-images me-2" style="color:var(--accent);"></i>Product Images</h6>
                                <div class="row g-4">
                                    <div class="col-md-5">
                                        <label class="form-label">Cover Image <span class="text-danger">*</span></label>
                                        <input type="file" name="coverImage" class="form-control" accept="image/*" required
                                               onchange="previewImg(this, 'coverPreview', 'coverPlaceholder')" />
                                        <div class="mt-3 rounded-2 d-flex align-items-center justify-content-center overflow-hidden"
                                             style="height:180px;background:white;border:2px dashed #e5e7eb;">
                                            <img id="coverPreview" src="#" class="d-none w-100 h-100" style="object-fit:contain;">
                                            <div id="coverPlaceholder" class="text-center text-muted">
                                                <i class="bi bi-image" style="font-size:2rem;opacity:0.3;"></i>
                                                <p class="mb-0 mt-2" style="font-size:0.78rem;">Preview here</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-7">
                                        <label class="form-label">Gallery Images</label>
                                        <input type="file" name="productImages" class="form-control" accept="image/*" multiple />
                                        <p class="text-muted mt-2 mb-0" style="font-size:0.78rem;">
                                            <i class="bi bi-info-circle me-1"></i>Select multiple images for the product gallery.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SUBMIT -->
                        <div class="col-12 d-flex gap-3">
                            <button type="submit" class="btn btn-accent px-5 py-2 fw-600">
                                <i class="bi bi-check2-circle me-2"></i>Create Product
                            </button>
                            <button type="reset" class="btn py-2 px-4 fw-600" style="background:#f3f4f6;color:#374151;border-radius:10px;">
                                Reset
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImg(input, previewId, placeholderId) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById(previewId).src = e.target.result;
                    document.getElementById(previewId).classList.remove('d-none');
                    document.getElementById(placeholderId).classList.add('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
