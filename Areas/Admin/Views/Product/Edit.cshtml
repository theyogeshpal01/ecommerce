@model GiftStoreMVC.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    Layout = "_AdminLayout";
    var categories = ViewBag.Categories as List<GiftStoreMVC.Models.Category>;
}

<div class="row justify-content-center">
    <div class="col-xl-10">
        <div class="admin-card">
            <div class="admin-card-header">
                <h6><i class="bi bi-pencil-fill me-2" style="color:var(--accent);"></i>Edit: @Model.Name</h6>
                <a asp-action="Index" class="btn btn-sm py-1 px-3 fw-600" style="background:#f3f4f6;color:#374151;border-radius:8px;font-size:0.8rem;text-decoration:none;">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
            <div class="admin-card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" style="font-size:0.85rem;"></div>

                    <div class="row g-4">
                        <div class="col-md-8">
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label">Product Name</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger" style="font-size:0.78rem;"></span>
                            </div>
                            <div class="mb-4">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="7"></textarea>
                                <span asp-validation-for="Description" class="text-danger" style="font-size:0.78rem;"></span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="p-4 rounded-2 mb-4" style="background:#f8f7ff;border:1px solid #ede9fe;">
                                <h6 class="fw-700 mb-3" style="font-size:0.85rem;">Pricing & Stock</h6>
                                <div class="mb-3">
                                    <label asp-for="CategoryId" class="form-label">Category</label>
                                    <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(categories, "Id", "Name"))"></select>
                                    <span asp-validation-for="CategoryId" class="text-danger" style="font-size:0.78rem;"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label">Price (₹)</label>
                                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                    <span asp-validation-for="Price" class="text-danger" style="font-size:0.78rem;"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="StockQuantity" class="form-label">Stock Quantity</label>
                                    <input asp-for="StockQuantity" class="form-control" type="number" />
                                    <span asp-validation-for="StockQuantity" class="text-danger" style="font-size:0.78rem;"></span>
                                </div>
                                <div class="d-flex align-items-center gap-3 p-3 rounded-2" style="background:white;border:1px solid #e5e7eb;">
                                    <input class="form-check-input m-0" type="checkbox" asp-for="IsFeatured" style="width:18px;height:18px;accent-color:var(--accent);">
                                    <div>
                                        <label class="form-label mb-0" asp-for="IsFeatured">Featured Product</label>
                                        <p class="text-muted mb-0" style="font-size:0.75rem;">Show on homepage</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- IMAGES -->
                        <div class="col-12">
                            <div class="p-4 rounded-2" style="background:#f8f7ff;border:1px solid #ede9fe;">
                                <h6 class="fw-700 mb-4" style="font-size:0.85rem;"><i class="bi bi-images me-2" style="color:var(--accent);"></i>Product Images</h6>
                                <div class="row g-4">
                                    <div class="col-md-4">
                                        <label class="form-label">Current Cover Image</label>
                                        <div class="rounded-2 overflow-hidden mb-2" style="height:160px;background:white;border:1px solid #e5e7eb;display:flex;align-items:center;justify-content:center;">
                                            <img src="@Model.CoverImageUrl" class="w-100 h-100" style="object-fit:contain;">
                                        </div>
                                        <input type="file" name="coverImage" class="form-control form-control-sm" accept="image/*" />
                                        <p class="text-muted mt-1 mb-0" style="font-size:0.75rem;">Upload to replace</p>
                                    </div>
                                    <div class="col-md-8">
                                        <label class="form-label">Gallery Images</label>
                                        <div class="d-flex flex-wrap gap-2 p-3 rounded-2 mb-2" style="min-height:120px;background:white;border:1px solid #e5e7eb;">
                                            @if (Model.ProductImages != null && Model.ProductImages.Any())
                                            {
                                                @foreach (var img in Model.ProductImages)
                                                {
                                                    <div class="position-relative">
                                                        <img src="@img.ImageUrl" class="rounded-2" style="width:80px;height:80px;object-fit:cover;">
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="text-muted d-flex align-items-center justify-content-center w-100" style="font-size:0.8rem;">
                                                    <i class="bi bi-images me-2"></i> No gallery images
                                                </div>
                                            }
                                        </div>
                                        <input type="file" name="productImages" class="form-control form-control-sm" accept="image/*" multiple />
                                        <p class="text-muted mt-1 mb-0" style="font-size:0.75rem;">Add more gallery images</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 d-flex gap-3">
                            <button type="submit" class="btn btn-accent px-5 py-2 fw-600">
                                <i class="bi bi-check2-circle me-2"></i>Save Changes
                            </button>
                            <a asp-action="Index" class="btn py-2 px-4 fw-600" style="background:#f3f4f6;color:#374151;border-radius:10px;text-decoration:none;">
                                Cancel
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
