@model IEnumerable<GiftStoreMVC.Models.Review>
@{
    ViewData["Title"] = "Manage Reviews";
    Layout = "_AdminLayout";
}

<div class="admin-card mb-4">
    <div class="admin-card-body p-3">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label mb-1" style="font-size:0.8rem;">Category</label>
                <select name="categoryId" class="form-select" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach(var cat in ViewBag.Categories)
                        {
                            if(ViewBag.SelectedCategoryId == cat.Id) { <option value="@cat.Id" selected>@cat.Name</option> }
                            else { <option value="@cat.Id">@cat.Name</option> }
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label mb-1" style="font-size:0.8rem;">Product</label>
                <select name="productId" class="form-select" onchange="this.form.submit()">
                    <option value="">All Products</option>
                    @if (ViewBag.Products != null)
                    {
                        foreach(var prod in ViewBag.Products)
                        {
                            if(ViewBag.SelectedProductId == prod.Id) { <option value="@prod.Id" selected>@prod.Name</option> }
                            else { <option value="@prod.Id">@prod.Name</option> }
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <a href="/Admin/Review" class="btn btn-outline-dark">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h6><i class="bi bi-star-fill me-2" style="color:#f59e0b;"></i>Product Reviews <span class="text-muted fw-400" style="font-size:0.8rem;">(@Model.Count())</span></h6>
    </div>
    <div style="overflow-x:auto;">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Customer</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="row-@item.Id">
                        <td>
                            <span class="fw-600" style="font-size:0.82rem;">@item.Product?.Name</span>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:30px;height:30px;border-radius:8px;background:#ede9fe;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;color:#7c3aed;flex-shrink:0;">
                                    @(item.User?.FullName?.Substring(0,1).ToUpper() ?? "?")
                                </div>
                                <span style="font-size:0.82rem;">@item.User?.FullName</span>
                            </div>
                        </td>
                        <td>
                            <div style="color:#f59e0b;font-size:0.75rem;letter-spacing:1px;">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi bi-star-fill @(i <= item.Rating ? "" : "text-muted opacity-25")"></i>
                                }
                            </div>
                        </td>
                        <td style="max-width:220px;">
                            <span style="font-size:0.82rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                @item.Comment
                            </span>
                        </td>
                        <td>
                            @if (item.IsApproved)
                            {
                                <span class="status-badge badge-approved">Approved</span>
                            }
                            else
                            {
                                <span class="status-badge badge-review-pending">Pending</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                @if (!item.IsApproved)
                                {
                                    <button class="btn-sm-icon" style="background:#d1fae5;color:#059669;" title="Approve"
                                            onclick="approveReview(@item.Id)">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                }
                                <button class="btn-sm-icon" style="background:#fee2e2;color:#ef4444;" title="Delete"
                                        onclick="deleteReview(@item.Id)">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function approveReview(id) {
            $.post('/Admin/Review/Approve/' + id, function (res) {
                if (res.success) location.reload();
            });
        }
        function deleteReview(id) {
            Swal.fire({
                title: 'Delete Review?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Delete',
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/Review/Delete/' + id, function (res) {
                        if (res.success) {
                            $('#row-' + id).fadeOut(300);
                            Swal.fire({ title: 'Deleted!', icon: 'success', timer: 1200, showConfirmButton: false });
                        }
                    });
                }
            });
        }
    </script>
}
