@{
    ViewData["Title"] = "Contact Us";
}

<!-- Contact Hero -->
<section class="py-5 bg-light mb-5">
    <div class="container py-5 text-center">
        <h1 class="display-4 fw-700 mb-3 text-uppercase">Contact Us</h1>
        <p class="lead text-muted mb-0 max-w-600 mx-auto">We're here to help. Reach out to us for any questions regarding products, orders, or styling advice.</p>
    </div>
</section>

<div class="container py-5">
    <div class="row g-5 justify-content-center">
        <div class="col-lg-10">
            <div class="row g-4 mb-5 text-center border-bottom pb-5">
                <!-- Info Cards -->
                <div class="col-md-4">
                    <i class="bi bi-geo-alt fs-2 mb-3 text-primary d-block"></i>
                    <h5 class="fw-bold mb-2">Our Studio</h5>
                    <p class="text-muted mb-0">123 Creative Plaza, Suite 100<br>Design District, NY 10001</p>
                </div>
                <div class="col-md-4">
                    <i class="bi bi-chat-dots fs-2 mb-3 text-primary d-block"></i>
                    <h5 class="fw-bold mb-2">Live Chat</h5>
                    <p class="text-muted mb-0">Available Mon-Fri<br>9:00 AM - 6:00 PM EST</p>
                </div>
                <div class="col-md-4">
                    <i class="bi bi-envelope fs-2 mb-3 text-primary d-block"></i>
                    <h5 class="fw-bold mb-2">Email Support</h5>
                    <p class="text-muted mb-0">hello@presento.com<br>support@presento.com</p>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="row g-5">
                <div class="col-lg-7">
                    <h3 class="fw-700 mb-4 text-uppercase">Send us a Message</h3>
                    
                    <form asp-controller="Home" asp-action="Index" method="get">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Full Name *</label>
                                <input type="text" class="form-control rounded-0 bg-light" id="nameInput" placeholder="John Doe" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email Address *</label>
                                <input type="email" class="form-control rounded-0 bg-light" id="emailInput" placeholder="name@example.com" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Subject *</label>
                                <input type="text" class="form-control rounded-0 bg-light" id="subjectInput" placeholder="Order Inquiry" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Message *</label>
                                <textarea class="form-control rounded-0 bg-light" placeholder="How can we help?" id="messageInput" style="height: 150px" required></textarea>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-primary-custom w-100 py-3 rounded-0 fw-bold text-uppercase" style="letter-spacing: 1px;">
                                    Send Message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="col-lg-5">
                    <div class="bg-light p-4 p-md-5 h-100">
                        <div class="mb-5">
                            <h4 class="fw-bold mb-3 text-uppercase">Connect</h4>
                            <p class="text-muted small mb-4">Follow us for daily inspiration and exclusive offers.</p>
                            <div class="d-flex gap-3">
                                <a href="https://instagram.com" target="_blank" class="text-dark"><i class="bi bi-instagram fs-4"></i></a>
                                <a href="https://facebook.com" target="_blank" class="text-dark"><i class="bi bi-facebook fs-4"></i></a>
                                <a href="https://twitter.com" target="_blank" class="text-dark"><i class="bi bi-twitter-x fs-4"></i></a>
                            </div>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-4 text-uppercase">Why Presento?</h4>
                            <div class="d-flex mb-3 align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-3 fs-5"></i>
                                <div>
                                    <h6 class="fw-bold mb-0">Premium Quality</h6>
                                </div>
                            </div>
                            <div class="d-flex mb-3 align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-3 fs-5"></i>
                                <div>
                                    <h6 class="fw-bold mb-0">Fast Shipping</h6>
                                </div>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-primary me-3 fs-5"></i>
                                <div>
                                    <h6 class="fw-bold mb-0">Secure Payment</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .max-w-600 { max-width: 600px; }
</style>
