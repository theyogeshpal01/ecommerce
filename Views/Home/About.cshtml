@{
    ViewData["Title"] = "About Us";
}

<!-- About Hero -->
<section class="py-5 bg-light mb-5">
    <div class="container py-5 text-center">
        <h1 class="display-4 fw-700 mb-3 text-uppercase">Our Story</h1>
        <p class="lead text-muted mb-0 max-w-600 mx-auto">We are more than just a gift store — we are creators of memories and deliverers of happiness, one gift at a time.</p>
    </div>
</section>

<!-- About Content -->
<div class="container py-5">
    <div class="row g-4 justify-content-center">
        <div class="col-lg-10">

            <!-- Stat Cards -->
            <div class="row g-4 mb-5 text-center">
                <div class="col-md-4">
                    <div class="border p-4 bg-white h-100">
                        <i class="bi bi-gift fs-2 mb-3 text-primary d-block"></i>
                        <h5 class="fw-bold mb-2">10,000+ Gifts</h5>
                        <p class="text-muted mb-0 fs-sm">Delivered with love<br>across the country</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border p-4 bg-white h-100">
                        <i class="bi bi-people fs-2 mb-3 text-primary d-block"></i>
                        <h5 class="fw-bold mb-2">5,000+ Customers</h5>
                        <p class="text-muted mb-0 fs-sm">Happy smiles and<br>5-star reviews</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border p-4 bg-white h-100">
                        <i class="bi bi-award fs-2 mb-3 text-primary d-block"></i>
                        <h5 class="fw-bold mb-2">Since 2026</h5>
                        <p class="text-muted mb-0 fs-sm">Crafting premium<br>gifting experiences</p>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="row g-5 align-items-center mb-5">
                <div class="col-lg-6">
                    <img src="https://images.unsplash.com/photo-1549465220-1d8c9d9c6703?w=800" class="img-fluid w-100 object-fit-cover" alt="About Presento" style="height: 400px;">
                </div>
                <div class="col-lg-6">
                    <h2 class="fw-700 mb-4 text-uppercase">About Presento</h2>
                    <p class="text-muted mb-4">Founded in 2026, Presento was born out of a simple idea: making gifting personal, easy, and premium. We curate the finest products from across the globe, ensuring that every gift you send tells a unique story.</p>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center border-bottom pb-2">
                            <i class="bi bi-patch-check-fill me-3 fs-5 text-primary"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Premium Quality</h6>
                                <small class="text-muted">Handpicked selection of the best gifts.</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center border-bottom pb-2">
                            <i class="bi bi-truck me-3 fs-5 text-primary"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Fast Delivery</h6>
                                <small class="text-muted">Delivered to your door in 2-3 days.</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-leaf me-3 fs-5 text-primary"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Eco-Friendly</h6>
                                <small class="text-muted">Sustainable packaging, always.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mission Section -->
            <div class="p-5 text-center bg-dark text-white my-5">
                <h2 class="fw-700 mb-3 text-white text-uppercase">Our Mission</h2>
                <p class="lead mx-auto mb-0" style="max-width: 700px; color: #ccc;">To bridge the distance between loved ones through thoughtful, personalized, and high-quality gifts that inspire joy and connection.</p>
            </div>

        </div>
    </div>
</div>

<style>
    .max-w-600 { max-width: 600px; }
    .object-fit-cover { object-fit: cover; }
    .fs-sm { font-size: 0.85rem; }
</style>
