@model IEnumerable<GiftStoreMVC.Models.CartItem>
@{
    ViewData["Title"] = "Your Cart";
    decimal subtotal = Model?.Sum(item => item.Product.Price * item.Quantity) ?? 0;
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">Shopping Cart</li>
        </ol>
    </nav>

    @if (Model != null && Model.Any())
    {
        <div class="row g-5">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-800 mb-0">Your Cart <span class="text-muted fw-400" style="font-size:1rem;">(@Model.Count() items)</span></h4>
                    <a asp-controller="Product" asp-action="Index" class="text-decoration-none fw-600" style="font-size:0.875rem;color:var(--accent);">
                        <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                    </a>
                </div>

                <div class="d-flex flex-column gap-3">
                    @foreach (var item in Model)
                    {
                        <div class="bg-white rounded-xl p-4 d-flex align-items-center gap-4 shadow-sm" style="border:1px solid var(--border);">
                            <!-- Image -->
                            <div class="rounded-lg overflow-hidden flex-shrink-0" style="width:90px;height:90px;background:#f8f7ff;display:flex;align-items:center;justify-content:center;">
                                <img src="@item.Product.CoverImageUrl" style="max-width:80px;max-height:80px;object-fit:contain;">
                            </div>
                            <!-- Info -->
                            <div class="flex-grow-1 min-w-0">
                                <h6 class="fw-700 mb-1" style="font-size:0.95rem;">@item.Product.Name</h6>
                                <p class="text-muted mb-2" style="font-size:0.8rem;">@(item.Product.Category?.Name ?? "Gift")</p>
                                <span class="fw-800" style="color:var(--accent);font-size:1rem;">@item.Product.Price.ToString("C")</span>
                            </div>
                            <!-- Qty Controls -->
                            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                <a asp-action="UpdateQuantity" asp-route-cartItemId="@item.Id" asp-route-quantity="@(item.Quantity - 1)"
                                   class="d-flex align-items-center justify-content-center rounded-lg fw-700 text-decoration-none"
                                   style="width:32px;height:32px;background:#f3f4f6;color:#374151;font-size:1rem;">−</a>
                                <span class="fw-700 text-center" style="width:32px;font-size:0.95rem;">@item.Quantity</span>
                                <a asp-action="UpdateQuantity" asp-route-cartItemId="@item.Id" asp-route-quantity="@(item.Quantity + 1)"
                                   class="d-flex align-items-center justify-content-center rounded-lg fw-700 text-decoration-none"
                                   style="width:32px;height:32px;background:#f3f4f6;color:#374151;font-size:1rem;">+</a>
                            </div>
                            <!-- Line Total -->
                            <div class="text-end flex-shrink-0" style="min-width:80px;">
                                <div class="fw-800" style="font-size:1rem;">@((item.Product.Price * item.Quantity).ToString("C"))</div>
                            </div>
                            <!-- Remove -->
                            <a asp-action="Remove" asp-route-id="@item.Id"
                               class="d-flex align-items-center justify-content-center rounded-lg flex-shrink-0 text-decoration-none"
                               style="width:34px;height:34px;background:#fee2e2;color:#ef4444;">
                                <i class="bi bi-x-lg" style="font-size:0.8rem;"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="bg-white rounded-xl p-4 shadow-sm" style="border:1px solid var(--border);position:sticky;top:90px;">
                    <h5 class="fw-800 mb-4">Order Summary</h5>

                    <div class="d-flex justify-content-between mb-3" style="font-size:0.9rem;">
                        <span class="text-muted">Subtotal</span>
                        <span class="fw-600">@subtotal.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4" style="font-size:0.9rem;">
                        <span class="text-muted">Shipping</span>
                        <span class="fw-600" style="color:#10b981;">Free</span>
                    </div>

                    <div class="mb-4 p-3 rounded-lg" style="background:#f8f7ff;border:1px dashed #ede9fe;">
                        <div class="d-flex gap-2">
                            <input type="text" class="form-control" placeholder="Coupon code" style="font-size:0.85rem;">
                            <button class="btn btn-accent px-3 flex-shrink-0" style="font-size:0.85rem;">Apply</button>
                        </div>
                    </div>

                    <div class="border-top pt-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-700" style="font-size:1rem;">Total</span>
                            <span class="fw-800" style="font-size:1.4rem;color:var(--accent);">@subtotal.ToString("C")</span>
                        </div>
                    </div>

                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary-custom w-100 py-3 justify-content-center" style="font-size:0.95rem;">
                        Proceed to Checkout <i class="bi bi-arrow-right ms-2"></i>
                    </a>

                    <div class="d-flex align-items-center justify-content-center gap-2 mt-3" style="font-size:0.78rem;color:#9ca3af;">
                        <i class="bi bi-shield-check"></i> Secure & encrypted checkout
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 my-5">
            <div class="d-inline-flex align-items-center justify-content-center rounded-xl mb-4"
                 style="width:100px;height:100px;background:#f8f7ff;">
                <i class="bi bi-cart-x" style="font-size:3rem;color:#c4b5fd;"></i>
            </div>
            <h3 class="fw-800 mb-2">Your cart is empty</h3>
            <p class="text-muted mb-4">Looks like you haven't added anything yet.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary-custom px-5 py-3">
                Start Shopping <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    }
</div>
