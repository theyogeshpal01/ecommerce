@model GiftStoreMVC.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    decimal subtotal = Model.CartItems.Sum(i => i.Product.Price * i.Quantity);
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Cart</a></li>
            <li class="breadcrumb-item active">Checkout</li>
        </ol>
    </nav>

    <!-- Steps -->
    <div class="d-flex align-items-center justify-content-center gap-3 mb-5">
        <div class="d-flex align-items-center gap-2">
            <div class="step-circle step-active">1</div>
            <span class="fw-600" style="font-size:0.875rem;">Details</span>
        </div>
        <div style="width:60px;height:2px;background:#e5e7eb;"></div>
        <div class="d-flex align-items-center gap-2">
            <div class="step-circle step-inactive">2</div>
            <span class="text-muted" style="font-size:0.875rem;">Shipping</span>
        </div>
        <div style="width:60px;height:2px;background:#e5e7eb;"></div>
        <div class="d-flex align-items-center gap-2">
            <div class="step-circle step-inactive">3</div>
            <span class="text-muted" style="font-size:0.875rem;">Payment</span>
        </div>
    </div>

    <form asp-action="Checkout" method="post">
        <div class="row g-5">
            <!-- LEFT: Billing Details -->
            <div class="col-lg-7">
                <div class="bg-white rounded-xl p-4 shadow-sm mb-4" style="border:1px solid var(--border);">
                    <h5 class="fw-800 mb-4">Billing Details</h5>

                    <div class="mb-4">
                        <label asp-for="ShippingAddress" class="form-label">Full Shipping Address <span class="text-danger">*</span></label>
                        <textarea asp-for="ShippingAddress" class="form-control" rows="4"
                                  placeholder="House no., Street, Area, City, State, PIN..."></textarea>
                        <span asp-validation-for="ShippingAddress" class="text-danger" style="font-size:0.78rem;"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Country</label>
                            <select class="form-select">
                                <option>India</option>
                                <option>USA</option>
                                <option>UK</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">State</label>
                            <input type="text" class="form-control" placeholder="e.g. Maharashtra">
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <input type="text" class="form-control" placeholder="e.g. Mumbai">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">PIN Code</label>
                            <input type="text" class="form-control" placeholder="400001">
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl p-4 shadow-sm" style="border:1px solid var(--border);">
                    <h5 class="fw-800 mb-4">Order Notes</h5>
                    <textarea class="form-control" rows="3" placeholder="Special instructions for delivery or gift message..."></textarea>
                </div>
            </div>

            <!-- RIGHT: Order Summary -->
            <div class="col-lg-5">
                <div class="bg-white rounded-xl p-4 shadow-sm" style="border:1px solid var(--border);position:sticky;top:90px;">
                    <h5 class="fw-800 mb-4">Order Summary</h5>

                    <!-- Items -->
                    <div class="d-flex flex-column gap-3 mb-4">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <div class="position-relative flex-shrink-0">
                                    <img src="@item.Product.CoverImageUrl" class="rounded-lg"
                                         style="width:52px;height:52px;object-fit:contain;background:#f8f7ff;border:1px solid #f3f4f6;">
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill"
                                          style="background:var(--accent);font-size:0.6rem;padding:3px 6px;">@item.Quantity</span>
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <p class="fw-600 mb-0 text-truncate" style="font-size:0.85rem;">@item.Product.Name</p>
                                </div>
                                <span class="fw-700 flex-shrink-0" style="font-size:0.875rem;">@((item.Product.Price * item.Quantity).ToString("C"))</span>
                            </div>
                        }
                    </div>

                    <div class="border-top pt-3 mb-3">
                        <div class="d-flex justify-content-between mb-2" style="font-size:0.875rem;">
                            <span class="text-muted">Subtotal</span>
                            <span class="fw-600">@subtotal.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3" style="font-size:0.875rem;">
                            <span class="text-muted">Shipping</span>
                            <span class="fw-600" style="color:#10b981;">Free</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-700">Total</span>
                            <span class="fw-800" style="font-size:1.3rem;color:var(--accent);">@subtotal.ToString("C")</span>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="mb-4">
                        <p class="fw-700 mb-3" style="font-size:0.85rem;">Payment Method</p>
                        <label class="d-flex align-items-center gap-3 p-3 rounded-lg cursor-pointer"
                               style="border:2px solid var(--accent);background:#f8f7ff;">
                            <input type="radio" name="payment" checked style="accent-color:var(--accent);">
                            <div>
                                <span class="fw-700" style="font-size:0.875rem;">Cash on Delivery</span>
                                <p class="text-muted mb-0" style="font-size:0.75rem;">Pay when your order arrives</p>
                            </div>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-3 justify-content-center" style="font-size:0.95rem;">
                        Place Order <i class="bi bi-check2-circle ms-2"></i>
                    </button>

                    <div class="d-flex align-items-center justify-content-center gap-2 mt-3" style="font-size:0.78rem;color:#9ca3af;">
                        <i class="bi bi-lock-fill"></i> Your data is safe & encrypted
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
