@model GiftStoreMVC.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="min-vh-100 d-flex align-items-center py-5" style="background: linear-gradient(135deg, #f8f7ff 0%, #fdf2f8 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">
                <div class="text-center mb-4 animate-up">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                        <h2 class="fw-800" style="font-size:2rem;letter-spacing:-1px;">Presento<span class="text-accent">.</span></h2>
                    </a>
                    <p class="text-muted mt-1" style="font-size:0.9rem;">Welcome back! Sign in to continue</p>
                </div>

                <div class="bg-white rounded-xl p-4 p-md-5 shadow-sm animate-up" style="animation-delay:0.1s;">
                    <!-- Role Toggle -->
                    <div class="d-flex bg-light p-1 rounded-xl mb-4" style="gap:4px;">
                        <button type="button" id="userBtn" class="btn flex-fill py-2 fw-600 rounded-lg" style="font-size:0.875rem;background:white;box-shadow:var(--shadow-sm);">
                            <i class="bi bi-person me-2"></i>User
                        </button>
                        <button type="button" id="adminBtn" class="btn flex-fill py-2 fw-600 rounded-lg text-muted" style="font-size:0.875rem;background:transparent;">
                            <i class="bi bi-shield-lock me-2"></i>Admin
                        </button>
                    </div>

                    <form asp-action="Login" method="post">
                        <input type="hidden" name="AttemptAdmin" id="AttemptAdmin" value="false" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="font-size:0.85rem;"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger" style="font-size:0.78rem;"></span>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label asp-for="Password" class="form-label mb-0">Password</label>
                                <a href="#" class="text-decoration-none fw-600" style="font-size:0.8rem;color:var(--accent);">Forgot?</a>
                            </div>
                            <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger" style="font-size:0.78rem;"></span>
                        </div>

                        <button type="submit" class="btn btn-primary-custom w-100 py-3 mb-3 justify-content-center" style="font-size:0.95rem;">
                            Sign In <i class="bi bi-arrow-right ms-2"></i>
                        </button>

                        <p class="text-center text-muted mb-0" style="font-size:0.85rem;">
                            New here?
                            <a asp-action="Register" class="fw-600 text-decoration-none" style="color:var(--accent);">Create an account</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const userBtn = document.getElementById('userBtn');
        const adminBtn = document.getElementById('adminBtn');
        const attemptAdmin = document.getElementById('AttemptAdmin');

        adminBtn.addEventListener('click', () => {
            adminBtn.style.background = 'white';
            adminBtn.style.boxShadow = 'var(--shadow-sm)';
            adminBtn.classList.remove('text-muted');
            userBtn.style.background = 'transparent';
            userBtn.style.boxShadow = 'none';
            userBtn.classList.add('text-muted');
            attemptAdmin.value = 'true';
        });
        userBtn.addEventListener('click', () => {
            userBtn.style.background = 'white';
            userBtn.style.boxShadow = 'var(--shadow-sm)';
            userBtn.classList.remove('text-muted');
            adminBtn.style.background = 'transparent';
            adminBtn.style.boxShadow = 'none';
            adminBtn.classList.add('text-muted');
            attemptAdmin.value = 'false';
        });
    </script>
}
