@model IEnumerable<GiftStoreMVC.Models.WishlistItem>
@{
    ViewData["Title"] = "My Wishlist";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-heart-fill text-danger me-2"></i> My Wishlist</h2>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card h-100 overflow-hidden border-0 shadow-sm position-relative">
                        <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-sm btn-light position-absolute top-0 end-0 m-2 rounded-circle shadow-sm">
                            <i class="bi bi-x"></i>
                        </a>
                        <img src="@item.Product.CoverImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@item.Product.Name">
                        <div class="card-body p-3 text-center">
                            <h6 class="fw-bold mb-1">@item.Product.Name</h6>
                            <p class="text-primary fw-bold mb-3">@item.Product.Price.ToString("C")</p>
                            <div class="d-grid gap-2">
                                <a asp-controller="Cart" asp-action="Add" asp-route-productId="@item.Product.Id" class="btn btn-primary btn-sm">
                                    Add to Cart
                                </a>
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Product.Id" class="btn btn-outline-secondary btn-sm">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-heart text-muted" style="font-size: 5rem;"></i>
            <h3 class="mt-4">Your wishlist is empty</h3>
            <p class="text-muted">Save the gifts you love to your wishlist and buy them later.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary mt-3 px-5">Explore Gifts</a>
        </div>
    }
</div>
