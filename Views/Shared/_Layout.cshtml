@using Microsoft.AspNetCore.Http
@using GiftStoreMVC.Data
@inject IHttpContextAccessor HttpContextAccessor
@inject ApplicationDbContext _context
@{
    var userId = HttpContextAccessor.HttpContext.Session.GetInt32("UserId");
    var userName = HttpContextAccessor.HttpContext.Session.GetString("UserName");
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
    var categories = _context.Categories.ToList();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Presento</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- HEADER -->
    <header class="main-header sticky-top border-bottom bg-white" id="mainHeader">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between py-2 gap-3">

                <!-- Logo -->
                <a class="navbar-brand flex-shrink-0 text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                    Presento.
                </a>

                <!-- Nav Links (Desktop) -->
                <nav class="d-none d-xl-flex align-items-center gap-1 me-auto ms-4">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index">Shop</a>
                    <div class="dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                            Categories
                        </a>
                        <ul class="dropdown-menu border-0 shadow-sm rounded-0">
                            @foreach (var cat in categories)
                            {
                                <li>
                                    <a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-category="@cat.Id">
                                        @cat.Name
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">About</a>
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                </nav>

                <!-- Search (Desktop) -->
                <form class="search-box d-none d-lg-flex flex-grow-1 border-0 border-bottom rounded-0 px-0" style="max-width:250px;" action="/Product/Index" method="get">
                    <i class="bi bi-search text-muted me-2 flex-shrink-0" style="font-size:0.85rem;"></i>
                    <input type="text" name="search" placeholder="Search gifts..." class="border-0 bg-transparent w-100 outline-none shadow-none" style="font-size:0.875rem;">
                </form>

                <!-- Actions -->
                <div class="d-flex align-items-center gap-2">
                    <!-- Wishlist -->
                    @if (userId != null)
                    {
                        <a asp-controller="Wishlist" asp-action="Index" class="btn btn-link text-dark p-2 d-flex align-items-center justify-content-center position-relative" title="Wishlist">
                            <i class="bi bi-heart" style="font-size:1.1rem;"></i>
                        </a>
                    }

                    <!-- Cart -->
                    @await Component.InvokeAsync("CartSummary")

                    <!-- User -->
                    @if (userId != null)
                    {
                        <div class="dropdown">
                            <button class="btn btn-link text-dark p-2 d-flex align-items-center justify-content-center" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person" style="font-size:1.2rem;"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-0">
                                <li class="px-3 py-2 border-bottom mb-1">
                                    <small class="text-muted d-block" style="font-size:0.72rem;">Signed in as</small>
                                    <span class="fw-700 text-dark" style="font-size:0.9rem;">@userName</span>
                                </li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                <li><a class="dropdown-item" asp-controller="Order" asp-action="History"><i class="bi bi-bag me-2"></i>My Orders</a></li>
                                <li><a class="dropdown-item" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart me-2"></i>Wishlist</a></li>
                                @if (userRole != null && userRole.Equals("Admin", StringComparison.OrdinalIgnoreCase))
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item fw-600" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Admin Panel</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-link text-dark fw-600 px-3 text-uppercase" style="font-size:0.875rem; text-decoration:none;">
                            Sign In
                        </a>
                    }

                    <!-- Mobile Toggle -->
                    <button class="btn btn-link text-dark d-xl-none p-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
                        <i class="bi bi-list" style="font-size:1.5rem;"></i>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- MOBILE OFFCANVAS MENU -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu" style="width:300px;">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-700 text-uppercase">Presento.</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">
            <!-- Mobile Search -->
            <div class="p-3 border-bottom">
                <form class="search-box border-bottom rounded-0 px-0" action="/Product/Index" method="get">
                    <i class="bi bi-search text-muted me-2"></i>
                    <input type="text" name="search" placeholder="Search gifts..." class="border-0 bg-transparent w-100 outline-none shadow-none" style="font-size:0.875rem;">
                </form>
            </div>
            <nav class="p-3">
                <a class="d-flex align-items-center gap-3 p-3 text-decoration-none text-dark fw-600 mb-1 text-uppercase" asp-controller="Home" asp-action="Index" style="font-size:0.9rem;" data-bs-dismiss="offcanvas">
                    Home
                </a>
                <a class="d-flex align-items-center gap-3 p-3 text-decoration-none text-dark fw-600 mb-1 text-uppercase" asp-controller="Product" asp-action="Index" style="font-size:0.9rem;" data-bs-dismiss="offcanvas">
                    Shop
                </a>
                <div class="ps-4">
                    @foreach (var cat in categories)
                    {
                        <a class="d-flex align-items-center gap-3 p-2 text-decoration-none text-muted mb-1 text-uppercase" asp-controller="Product" asp-action="Index" asp-route-category="@cat.Id" style="font-size:0.8rem;" data-bs-dismiss="offcanvas">
                            @cat.Name
                        </a>
                    }
                </div>
                <a class="d-flex align-items-center gap-3 p-3 text-decoration-none text-dark fw-600 mb-1 text-uppercase" asp-controller="Home" asp-action="Contact" style="font-size:0.9rem;" data-bs-dismiss="offcanvas">
                    Contact
                </a>
                @if (userId == null)
                {
                    <div class="mt-4 pt-4 border-top">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary-custom w-100 mb-2 rounded-0" data-bs-dismiss="offcanvas">Sign In</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-dark w-100 rounded-0" data-bs-dismiss="offcanvas">Create Account</a>
                    </div>
                }
            </nav>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main role="main">
        @if (TempData["Success"] != null)
        {
            <div class="container mt-4">
                <div class="alert alert-success rounded-0 d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                    <span>@TempData["Success"]</span>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-4">
                <div class="alert alert-danger rounded-0 d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                    <span>@TempData["Error"]</span>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer-v3 bg-white mt-5 pt-5 pb-3 border-top">
        <div class="container">
            <div class="row g-5 mb-5">
                <div class="col-lg-4">
                    <h3 class="fw-700 text-dark mb-3 text-uppercase" style="letter-spacing:1px;">Presento.</h3>
                    <p class="mb-4 text-muted" style="font-size:0.9rem;line-height:1.6;">Curating minimal, high-quality gifts. Uncomplicated, beautiful, and thoughtful presents.</p>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-dark"><i class="bi bi-instagram fs-5"></i></a>
                        <a href="#" class="text-dark"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" class="text-dark"><i class="bi bi-twitter-x fs-5"></i></a>
                        <a href="#" class="text-dark"><i class="bi bi-pinterest fs-5"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2 ms-lg-auto">
                    <h6 class="text-dark fw-bold text-uppercase mb-4">Shop</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index" class="text-muted text-decoration-none">All Products</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index" asp-route-sort="newest" class="text-muted text-decoration-none">New Arrivals</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index" class="text-muted text-decoration-none">Best Sellers</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index" asp-route-search="gift" class="text-muted text-decoration-none">Gift Cards</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="text-dark fw-bold text-uppercase mb-4">Company</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Home" asp-action="About" class="text-muted text-decoration-none">Our Story</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Contact" class="text-muted text-decoration-none">Contact Us</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Privacy Policy</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Terms of Service</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="text-dark fw-bold text-uppercase mb-4">Newsletter</h6>
                    <p class="text-muted mb-3" style="font-size:0.85rem;">Get 10% off your first order. No spam, ever.</p>
                    <form class="d-flex border-bottom border-dark pb-2" method="get" action="/Home/Index">
                        <input type="email" name="email" class="border-0 bg-transparent flex-grow-1 outline-none shadow-none text-dark px-0" placeholder="Your email" required>
                        <button type="submit" class="btn btn-link text-dark p-0 fw-bold text-decoration-none text-uppercase" style="font-size: 0.85rem;">Subscribe</button>
                    </form>
                </div>
            </div>
            <div class="border-top pt-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                <p class="mb-0 text-muted" style="font-size:0.85rem;">&copy; 2026 Presento Store. Minimalist aesthetic. Designed and developed by Vanshika.</p>
                <div class="d-flex gap-3 text-muted" style="font-size:0.85rem;">
                    <a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Privacy</a>
                    <a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Terms</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
