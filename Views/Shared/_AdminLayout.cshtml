<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; background-color: #f3f4f6; }
        .sidebar { width: 260px; height: 100vh; position: fixed; background: #1e293b; color: #fff; z-index: 1000; }
        .main-content { margin-left: 260px; padding: 2rem; min-height: 100vh; }
        .nav-link { color: #94a3b8; padding: 0.8rem 1.5rem; border-radius: 8px; margin: 0.2rem 1rem; transition: all 0.2s; }
        .nav-link:hover { color: #fff; background: rgba(255,255,255,0.1); }
        .nav-link.active { color: #fff; background: #6366f1; }
        .card { border: none; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .stat-card { transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-5px); }
    </style>
</head>
<body>
    <div class="sidebar d-none d-lg-block">
        <div class="p-4 mb-4">
            <h4 class="fw-bold mb-0 text-white"><i class="bi bi-gift-fill me-2 text-primary"></i>GiftStore</h4>
            <small class="text-muted">Admin Dashboard</small>
        </div>
        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")" asp-controller="Product" asp-action="Index">
                <i class="bi bi-box-seam me-2"></i> Products
            </a>
            <a class="nav-link" href="#">
                <i class="bi bi-tags me-2"></i> Categories
            </a>
            <a class="nav-link" href="#">
                <i class="bi bi-cart-check me-2"></i> Orders
            </a>
            <a class="nav-link" href="#">
                <i class="bi bi-people me-2"></i> Users
            </a>
            <a class="nav-link" href="#">
                <i class="bi bi-star me-2"></i> Reviews
            </a>
            <hr class="mx-3 opacity-10">
            <a class="nav-link" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house me-2"></i> View Store
            </a>
            <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                <i class="bi bi-box-arrow-right me-2"></i> Logout
            </a>
        </nav>
    </div>

    <div class="main-content">
        <header class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">@ViewData["Title"]</h2>
            <div class="dropdown">
                <button class="btn btn-white shadow-sm dropdown-toggle rounded-pill px-3" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle me-2 text-primary"></i> Admin
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Profile</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">Logout</a></li>
                </ul>
            </div>
        </header>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-alert="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
